# Local founder-demo mode works without environment variables.
VITE_OBSERI_DATA_MODE=local

# Hosted persistence and authentication (recommended: Supabase/Postgres).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional browser crawler service for JavaScript-heavy or protected sources.
# Crawl4AI or Scrapling can sit behind this HTTP boundary.
OBSERI_CRAWLER_API_URL=
OBSERI_CRAWLER_API_KEY=

# Optional OpenAI-compatible analysis provider (hosted model, Ollama, or proxy.py).
OBSERI_AI_API_URL=
OBSERI_AI_API_KEY=
OBSERI_AI_MODEL=

# Optional grounded-conversation override. Falls back to OBSERI_AI_* above.
OBSERI_CHAT_API_URL=
OBSERI_CHAT_API_KEY=
OBSERI_CHAT_MODEL=
# Optional low-latency model used only for live voice turns.
OBSERI_VOICE_MODEL=

# Pre-warmed Supertonic service used by consistent neural voices. Keep the key
# server-only and identical on the web app and voice container.
OBSERI_SUPERTONIC_URL=
OBSERI_SUPERTONIC_API_KEY=

# Fireworks example:
# OBSERI_CHAT_API_URL=https://api.fireworks.ai/inference/v1
# OBSERI_CHAT_MODEL=accounts/fireworks/routers/kimi-k2p6-turbo

# Optional Voicebox REST service. The sibling Docker checkout maps to port 17600.
# Browser speech remains the no-setup fallback when Voicebox is offline.
OBSERI_VOICEBOX_URL=http://127.0.0.1:17600
# Enable only on a GPU worker (or a CPU worker with enough dedicated RAM).
OBSERI_ENABLE_QWEN_VOICES=false

# Delivery and billing adapters.
RESEND_API_KEY=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DATABASE_URL=
OBSERI_WIDGET_SESSION_SECRET=
OBSERI_SECRET_ENCRYPTION_KEY=
CRON_SECRET=
